# ╔══════════════════════════════════════════════════════════════╗
# ║   VARIÁVEIS DE AMBIENTE — .env                               ║
# ║   IMPORTANTE: Nunca compartilhe este arquivo publicamente!   ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Instruções de onde obter cada valor estão abaixo.
# Após preencher, renomeie este arquivo de ".env.example" para ".env"

# ─────────────────────────────────────────────
# 1. GROQ API KEY
#    Obtenha em: https://console.groq.com
#    Clique em "API Keys" > "Create API Key"
# ─────────────────────────────────────────────
GROQ_API_KEY=sua_chave_groq_aqui

# ─────────────────────────────────────────────
# 2. WHATSAPP TOKEN (Token de Acesso Permanente)
#    Obtenha em: https://developers.facebook.com
#    Crie um App > WhatsApp > Configurações da API
# ─────────────────────────────────────────────
WHATSAPP_TOKEN=seu_token_whatsapp_aqui

# ─────────────────────────────────────────────
# 3. PHONE NUMBER ID
#    Encontrado em: Meta for Developers > WhatsApp > Configurações da API
#    É o ID numérico do seu número WhatsApp Business
# ─────────────────────────────────────────────
PHONE_NUMBER_ID=seu_phone_number_id_aqui

# ─────────────────────────────────────────────
# 4. VERIFY TOKEN (você mesmo escolhe este valor)
#    Use qualquer palavra/frase segura. Ex: optalife2026
#    Este valor será digitado no painel da Meta ao configurar o Webhook
# ─────────────────────────────────────────────
VERIFY_TOKEN=optalife2026
